# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-замените-на-безопасный-ключ
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── База данных ──────────────────────────────────────────────────────────────
# Значения: sqlite (по умолчанию) | mariadb | postgresql
DB_ENGINE=mariadb

# Параметры MariaDB / MySQL (заполнять если DB_ENGINE=mariadb)
DB_NAME=finansovaya_kultura
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Параметры PostgreSQL (заполнять если DB_ENGINE=postgresql)
# DB_NAME=finansovaya_kultura
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# ─── CORS (фронтенд) ──────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:5500

# ─── Email ─────────────────────────────────────────────────────────────────────
# Для разработки (письма в консоль, без реальной отправки):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Для продакшена раскомментировать и заполнить:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Яндекс.Почта:
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465
# EMAIL_USE_SSL=True
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=your@yandex.ru
# EMAIL_HOST_PASSWORD=app-password-from-yandex

# Gmail:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_SSL=False
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=app-password-from-google

DEFAULT_FROM_EMAIL=Школа финансовой культуры <noreply@finansy.ru>

# URL фронтенда (для ссылок в письмах)
FRONTEND_URL=http://localhost:5173
